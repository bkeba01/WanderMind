# ==========================================
# WanderMind MVP - 外部APIアクセスキー
# ==========================================

# 1. OpenAIのAPIキー（"sk-"から始まる文字列）
GEMINI_API_KEY=

# 2. Google CloudのAPIキー（Places / Routes共通）
GOOGLE_MAPS_API_KEY=


# ==========================================
# 検証用の固定入力値（ユーザー入力のバリデーション用）
# ==========================================

# ユーザーの抽象的な気分（例: リフレッシュしたい, のんびりしたい, 刺激がほしい）
USER_MOOD=リフレッシュしたい

# 空き時間（分単位。整数値のみ）
USER_FREE_TIME_MINUTES=120

# 基準となる現在地の緯度経度（例は船橋駅周辺）
USER_LATITUDE=35.7008
USER_LONGITUDE=139.9877